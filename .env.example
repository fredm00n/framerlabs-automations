# Notion integration token (Settings > Connections > Develop or manage integrations)
NOTION_TOKEN=

# Notion database IDs (find in the DB page URL)
NOTION_DATABASE_ID=        # Framer Templates DB
NOTION_REDDIT_LEADS_DB_ID= # Reddit Leads DB

# Discord webhooks (Server Settings > Integrations > Webhooks)
DISCORD_WEBHOOK_URL_TEMPLATES= # New template notifications
DISCORD_WEBHOOK_URL_LEADS=     # Approved lead notifications
DISCORD_ALERTS_WEBHOOK_URL=    # System-level errors and warnings (separate channel)

# Logged-out Reddit cookie (edgebucket + loid) for reddit_leads.py RSS fetches.
# Optional: if unset the script still works but anonymous RSS is throttled to
# ~1 req/60s per IP, producing HTTP 429s when fetching all feeds. A browser-minted
# loid moves requests into the ~100/10min visitor bucket and works from any IP.
# Harvest from a logged-out reddit.com session (DevTools > Network > any request >
# Request Headers > Cookie). loid is multi-year; re-harvest if 429s return.
REDDIT_COOKIE=

# Twitter/X API credentials (optional — X posting is skipped if not set)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
